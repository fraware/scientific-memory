{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scientific-memory.org/schemas/proof_repair_apply_bundle.schema.json",
  "title": "Human-reviewed proof-repair apply bundle",
  "description": "Patches to Lean sources; only applied via CLI with explicit human-review flags. Never used from CI.",
  "type": "object",
  "additionalProperties": false,
  "required": ["verification_boundary", "patches"],
  "properties": {
    "verification_boundary": { "type": "string", "const": "human_review_only" },
    "review_record_path": {
      "type": "string",
      "description": "Optional path to a review record JSON committed alongside the apply."
    },
    "patches": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["relative_path", "replacements"],
        "properties": {
          "relative_path": {
            "type": "string",
            "description": "Repo-relative path under formal/ (e.g. formal/ScientificMemory/Foo.lean)"
          },
          "replacements": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["find", "replace"],
              "properties": {
                "find": { "type": "string", "minLength": 1 },
                "replace": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
