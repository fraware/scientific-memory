{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scientific-memory.org/schemas/llm_run_provenance.schema.json",
  "title": "LLM run provenance (model + inputs + review)",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "provider": { "type": "string" },
    "model": { "type": "string" },
    "model_version": { "type": "string" },
    "created_at": { "type": "string" },
    "latency_seconds": { "type": "number" },
    "temperature": { "type": "number" },
    "top_p": { "type": "number" },
    "max_tokens": { "type": "integer" },
    "seed": { "type": "integer" },
    "prompt_template_id": { "type": "string" },
    "prompt_template_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "input_artifact_sha256": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "prompt_tokens": { "type": "integer" },
    "completion_tokens": { "type": "integer" },
    "total_tokens": { "type": "integer" },
    "estimated_cost_usd": { "type": "number" },
    "reviewer_time_seconds": {
      "type": "number",
      "minimum": 0,
      "description": "Optional wall time spent by a human reviewer on this bundle (eval harness aggregate only)."
    },
    "reviewer_decision": {
      "type": "string",
      "enum": ["pending", "accepted", "rejected", "edited"]
    },
    "promotion_outcome": { "type": "string" },
    "notes": { "type": "string" }
  }
}
