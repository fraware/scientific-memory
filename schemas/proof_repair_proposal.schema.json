{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scientific-memory.org/schemas/proof_repair_proposal.schema.json",
  "title": "Proof repair proposal (human_review_only)",
  "description": "Proposals generated by proof-repair workflow; never auto-applied. verification_boundary is always human_review_only.",
  "type": "object",
  "additionalProperties": false,
  "required": ["verification_boundary", "proposals", "generated_at"],
  "properties": {
    "verification_boundary": {
      "type": "string",
      "const": "human_review_only"
    },
    "generated_at": { "type": "string", "format": "date-time" },
    "paper_id": { "type": "string", "description": "Optional; present when scoped to one paper." },
    "proposals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["theorem_card_id", "paper_id", "lean_decl", "file_path", "current_proof_status", "suggested_action"],
        "properties": {
          "theorem_card_id": { "type": "string" },
          "paper_id": { "type": "string" },
          "claim_id": { "type": "string" },
          "lean_decl": { "type": "string" },
          "file_path": { "type": "string" },
          "current_proof_status": { "type": "string" },
          "current_verification_boundary": { "type": "string" },
          "suggested_action": { "type": "string" },
          "repair_hints": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
