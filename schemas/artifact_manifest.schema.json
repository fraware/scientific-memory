{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scientific-memory.org/schemas/artifact_manifest.schema.json",
  "title": "Artifact Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "paper_id",
    "version",
    "build_hash",
    "coverage_metrics",
    "generated_pages"
  ],
  "properties": {
    "paper_id": { "$ref": "common.schema.json#/$defs/id" },
    "version": { "type": "string" },
    "build_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "build_hash_version": {
      "type": "string",
      "description": "2 = content-addressed over corpus + cards + kernel_index; omit or 1 = legacy path-based fingerprint"
    },
    "coverage_metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_count",
        "mapped_claim_count",
        "machine_checked_count",
        "kernel_linked_count"
      ],
      "properties": {
        "claim_count": { "type": "integer", "minimum": 0 },
        "mapped_claim_count": { "type": "integer", "minimum": 0 },
        "machine_checked_count": { "type": "integer", "minimum": 0 },
        "kernel_linked_count": { "type": "integer", "minimum": 0 }
      }
    },
    "generated_pages": {
      "type": "array",
      "items": { "type": "string" }
    },
    "declaration_index": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "dependency_graph": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to"],
        "properties": {
          "from": { "$ref": "common.schema.json#/$defs/id" },
          "to": { "$ref": "common.schema.json#/$defs/id" },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"],
            "description": "Heuristic confidence from dependency extraction method on the consumer card (e.g. tier1 FQ refs -> high)."
          }
        }
      },
      "default": []
    },
    "kernel_index": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/id" },
      "default": []
    }
  }
}
