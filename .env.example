# Prime Intellect (OpenAI-compatible inference API). Copy to `.env` at repo root (gitignored).
# Docs: https://docs.primeintellect.ai/api-reference/inference-chat-completions
PRIME_INTELLECT_API_KEY=
# Optional override (default: https://api.pinference.ai/api/v1)
# PRIME_INTELLECT_BASE_URL=https://api.pinference.ai/api/v1
# Optional team header (see Prime Intellect dashboard)
# PRIME_INTELLECT_TEAM_ID=

# Per-task model routing (defaults to SM_LLM_MODEL_DEFAULT or a built-in fallback)
# SM_LLM_MODEL_DEFAULT=meta-llama/llama-3.1-70b-instruct
# SM_LLM_MODEL_CLAIMS=
# SM_LLM_MODEL_MAPPING=
# SM_LLM_MODEL_LEAN=

# SM_LLM_TIMEOUT_SECONDS=120
# SM_LLM_MAX_RETRIES=3
